{
    "id" : "io.gitlab.hinnerkm.Kairos",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "50",
    "sdk" : "org.gnome.Sdk",
    "command" : "kairos",
    "finish-args" : [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland",
        "--talk-name=org.gnome.evolution.dataserver.Calendar8",
        "--talk-name=org.gnome.evolution.dataserver.Sources5",
        "--talk-name=org.gnome.evolution.dataserver.Subprocess.Backend.*"

    ],
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/lib/girepository-1.0",
        "/share/gir-1.0",
        "/share/vala",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "/share/vala",
        "*.la",
        "*.a"
    ],
    "modules" : [
        {
            "name" : "libical",
            "cleanup" : [
                "/lib/cmake"
            ],
            "buildsystem" : "cmake-ninja",
            "config-opts" : [
                "-DBUILD_SHARED_LIBS=On",
                "-DICAL_BUILD_DOCS=False",
                "-DICAL_BUILD_TESTING=false",
                "-DICAL_GLIB=true",
                "-DICAL_GLIB_VAPI=true",
                "-DLIBICAL_GLIB_VAPI=true",
                "-DLIBICAL_GOBJECT_INTROSPECTION=true",
                "-DGOBJECT_INTROSPECTION=true",
                "-DCMAKE_BUILD_TYPE=RelWithDebInfo",
                "-DWITH_CXX_BINDINGS=false",
                "-DSHARED_ONLY=true"
            ],
            "sources" : [
                {
                  "type": "git",
                  "url": "https://github.com/libical/libical.git",
                  "tag": "v3.0.20",
                  "commit": "57ce34025066935f356fd539e6deb7a7a9952618"
                }
            ]
        },
        {
            "name": "evolution-data-server",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DWITH_OPENLDAP=OFF",
                "-DENABLE_GOA=OFF",
                "-DWITH_LIBDB=OFF",
                "-DENABLE_WEATHER=OFF",
                "-DENABLE_CANBERRA=OFF",
                "-DENABLE_GTK=OFF",
                "-DENABLE_GTK4=ON",
                "-DENABLE_TESTS=false",
                "-DENABLE_INSTALLED_TESTS=OFF",
                "-DENABLE_GTK_DOC=OFF",
                "-DENABLE_INTROSPECTION=ON",
                "-DENABLE_VALA_BINDINGS=ON",
                "-DENABLE_EXAMPLES=OFF",
                "-DENABLE_OAUTH2_WEBKITGTK4=OFF",
                "-DCMAKE_BUILD_TYPE=RelWithDebInfo"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.gnome.org/GNOME/evolution-data-server.git",
                    "tag": "3.58.0",
                    "commit": "aed3962e7d0914f4c5c04c6b6445cab1d935492e"
                }
            ]
        },
        {
            "name" : "kairos",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://gitlab.com/hinnerkm/Kairos",
                    "tag" : "0.2.1",
                    "commit" : "34ddb18ec0e4f77e87fb7f2d63c2cdce21261415"
                }
            ]
        }
    ]
}
